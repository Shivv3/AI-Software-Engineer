SESSION_SECRET=change-me

# You can provide comma-separated pools...
GEMINI_API_KEYS=
GROQ_API_KEYS=

# ...or numbered keys. The backend reads indexes 1 through 10.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# Backward-compatible single-key fallback.
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# Optional throttles for large project generation.
LLM_RATE_LIMIT_PER_MINUTE=84
PROJECT_GENERATION_CONCURRENCY=3
